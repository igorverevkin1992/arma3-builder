# Provider selection: gemini | anthropic | openai | ollama | stub
# Gemini is the default real provider. `stub` keeps tests / offline runs deterministic.
ARMA3_LLM_PROVIDER=stub

# API keys (only required when provider != stub)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model overrides — defaults are Gemini 2.5 (heavy/medium/light tiers).
ARMA3_MODEL_ORCHESTRATOR=gemini-2.5-pro
ARMA3_MODEL_NARRATIVE=gemini-2.5-pro
ARMA3_MODEL_SCRIPTER=gemini-2.5-flash
ARMA3_MODEL_CONFIG=gemini-2.5-flash
ARMA3_MODEL_QA=gemini-2.5-flash-lite

# Provider base URLs (override only for proxies / Vertex AI / private deploys)
ARMA3_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
ARMA3_OLLAMA_BASE_URL=http://localhost:11434

# RAG backend: memory | qdrant
ARMA3_RAG_BACKEND=memory
ARMA3_QDRANT_URL=http://localhost:6333
ARMA3_QDRANT_API_KEY=

# Output directory for generated campaigns
ARMA3_OUTPUT_DIR=./output

# QA strict mode: 1 = block on warnings, 0 = warnings only
ARMA3_QA_STRICT=1

# Maximum repair iterations between Scripter and QA
ARMA3_MAX_REPAIR_ITERATIONS=5
